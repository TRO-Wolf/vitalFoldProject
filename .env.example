# ── AWS Configuration ─────────────────────────────────────────────
# These variables are substituted into spark-defaults.conf at container startup.
# Copy this file to .env and replace the placeholder values with your own.
#
#   cp .env.example .env

AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-2
ICEBERG_S3_BUCKET=your-iceberg-warehouse-bucket
S3_TABLES_BUCKET=your-s3-tables-bucket

# ── Airflow docker-compose ────────────────────────────────────────
# Root for Airflow volume mounts (dags/, plugins/, includes/, config/, logs/).
# All Airflow code lives under ./airflow in this repo.
AIRFLOW_PROJ_DIR=./airflow
